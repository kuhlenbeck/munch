{
  "name": "food-journal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "NODE_OPTIONS=--experimental-sqlite ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:client": "cd client && npm run dev -- --host",
    "build": "cd client && npm run build && cd .. && npx tsc",
    "start": "node --experimental-sqlite dist/server.js",
    "export:csv": "node -e \"const {exportCSV}=require('./dist/database'); exportCSV().then(f=>console.log('Exported to',f))\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "openai": "^6.33.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
